{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "node", "oxc", "import"],
  "jsPlugins": ["../../.tooling/oxlint/architecture-boundaries.mjs"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "env": {
    "commonjs": true,
    "node": true
  },
  "ignorePatterns": ["node_modules/", "dist/"],
  "rules": {
    "architecture-boundaries/no-cross-layer-import": [
      "error",
      {
        "aliasPrefix": "src/",
        "boundaries": [{ "from": "*/core/**", "to": "*/adapters/**" }]
      }
    ],
    "typescript/ban-types": "error",
    "typescript/consistent-type-imports": "off",
    "no-await-in-loop": "off",
    "no-accumulating-spread": "off",
    "unicorn/prefer-node-protocol": "error",
    "unicorn/consistent-function-scoping": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-extraneous-class": [
      "error",
      {
        "allowWithDecorator": true
      }
    ],
    "import/no-named-as-default": "off",
    "typescript/no-confusing-void-expression": "error",
    "typescript/no-dynamic-delete": "error",
    "typescript/no-empty-object-type": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-asserted-nullish-coalescing": "error",
    "typescript/no-non-null-asserted-optional-chain": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-return": "error",
    "no-console": "error",
    "typescript/only-throw-error": "error",
    "prefer-promise-reject-errors": "error",
    "typescript/prefer-promise-reject-errors": "error",
    "typescript/prefer-reduce-type-parameter": "error",
    "typescript/prefer-return-this-type": "error",
    "require-await": "error",
    "typescript/require-await": "error",
    "typescript/use-unknown-in-catch-callback-variable": "error",
    "typescript/array-type": "error",
    "typescript/no-confusing-non-null-assertion": "error",
    "no-empty-function": "error",
    "typescript/non-nullable-type-assertion-style": "error",
    "typescript/prefer-ts-expect-error": "error",
    // Disabled pending per-rule evaluation after oxlint 1.43->1.72 upgrade (newly-triggered rules)
    "no-underscore-dangle": "off",
    "no-shadow": "off",
    "no-useless-assignment": "error",
    "typescript/no-unnecessary-condition": "off",
    "typescript/no-unnecessary-type-conversion": "error",
    "typescript/consistent-return": "off",
    "typescript/no-useless-default-assignment": "error",
    "typescript/parameter-properties": "error"
  },
  "overrides": [
    {
      // Node ESM loader hook: inherently untyped module APIs
      "files": ["test/swc-esm-loader.mjs"],
      "rules": {
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-return": "off"
      }
    },
    {
      "files": [
        "src/shared-kernel/adapters/sql-knex/migrations/**/*.ts",
        "src/shared-kernel/adapters/sql-knex/scripts/**/*.ts",
        "src/shared-kernel/adapters/sql-knex/seeds/**/*.ts",
        "test/integration-global-setup.mts",
        "test/integration-per-test-hooks.ts"
      ],
      "rules": {
        "no-console": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-useless-default-assignment": "off",
        "no-useless-assignment": "off"
      }
    },
    {
      "files": ["*.spec.ts", "*.integration-spec.ts"],
      "rules": {
        "typescript/no-floating-promises": "off",
        "typescript/no-non-null-assertion": "off",
        // Unit tests instantiate InMemory/Deterministic/Fake test doubles from adapters/
        // directly — the project's documented pattern (see api-modules-and-di.md).
        "architecture-boundaries/no-cross-layer-import": "off"
      }
    }
  ]
}
