{
  "$schema": "https://swc.rs/schema.json",
  "exclude": [".*\\.spec\\.ts$", ".*\\.integration-spec\\.ts$"],
  "sourceMaps": true,
  "jsc": {
    "target": "es2022",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true,
      "useDefineForClassFields": false
    },
    "keepClassNames": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "test/*": ["./test/*"]
    }
  },
  "module": {
    "type": "es6",
    "resolveFully": true
  }
}
