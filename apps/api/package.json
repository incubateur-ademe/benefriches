{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "pnpm start:dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "node --import ./test/swc-esm-loader.mjs --test 'src/**/*.spec.ts'",
    "test:integration": "node --import ./test/swc-esm-loader.mjs --import ./test/integration-per-test-hooks.ts --test-global-setup=./test/integration-global-setup.mts --test-concurrency=1 --test 'src/**/*.integration-spec.ts'",
    "lint": "oxlint",
    "format": "prettier --write --cache \"./**/*.{js,jsx,ts,tsx,css,md,json}\" src/ test/",
    "format:check": "prettier --check --cache  \"./**/*.{js,jsx,ts,tsx,css,md,json}\" src/ test/",
    "knex": "tsx node_modules/knex/bin/cli.js",
    "knex:new-migration": "pnpm knex migrate:make -x ts --knexfile=src/shared-kernel/adapters/sql-knex/knexfile.ts",
    "knex:migrate-latest": "pnpm knex migrate:latest --knexfile=src/shared-kernel/adapters/sql-knex/knexfile.ts",
    "knex:migrate-latest:js": "node node_modules/knex/bin/cli.js migrate:latest --knexfile=dist/src/shared-kernel/adapters/sql-knex/knexfile.js",
    "knex:migrate-rollback": "pnpm knex migrate:rollback --knexfile=src/shared-kernel/adapters/sql-knex/knexfile.ts",
    "knex:seed-make": "pnpm knex seed:make --knexfile=src/shared-kernel/adapters/sql-knex/knexfile.ts",
    "knex:seed-run": "pnpm knex seed:run --knexfile=src/shared-kernel/adapters/sql-knex/knexfile.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "~11.0.23",
    "@nestjs/schematics": "~11.1.0",
    "@nestjs/testing": "~11.1.27",
    "@swc/cli": "~0.8.1",
    "@swc/core": "^1.15.41",
    "@trivago/prettier-plugin-sort-imports": "~6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "~5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/geojson": "~7946.0.16",
    "@types/node": "~25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "~8.20.0",
    "@types/supertest": "~7.2.0",
    "cookie": "^1.1.1",
    "dotenv": "~17.2.3",
    "globals": "~17.6.0",
    "supertest": "~7.2.2",
    "testcontainers": "~12.0.2",
    "ts-node": "~10.9.2",
    "tsx": "~4.22.4"
  },
  "dependencies": {
    "@nestjs/axios": "~4.0.1",
    "@nestjs/common": "~11.1.27",
    "@nestjs/config": "~4.0.4",
    "@nestjs/core": "~11.1.27",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "~11.1.27",
    "@nestjs/swagger": "~11.4.4",
    "@nestjs/throttler": "~6.5.0",
    "axios": "~1.18.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^6.2.1",
    "date-fns": "~4.4.0",
    "dotenv": "~17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "knex": "~3.2.10",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^8.0.11",
    "openid-client": "^6.8.4",
    "pg": "~8.21.0",
    "reflect-metadata": "~0.2.2",
    "rxjs": "~7.8.2",
    "shared": "workspace:^",
    "uuid": "~14.0.0",
    "zod": "~4.4.3"
  }
}
