# Node runtime mode (`development` | `production` | `test`); enables prod-only behaviors like secure cookies and SSL DB connections
NODE_ENV=development
# Port the NestJS HTTP server listens on
PORT=4000

# Express session signing secret used for cookie integrity (sensitive)
SESSION_SECRET=use-a-robust-secret

# Public URL of the web app (used for OAuth post-login redirects and email links)
WEBAPP_URL=http://localhost:3000

# Auth
# JWT signing secret used by the auth module to issue and verify session tokens (sensitive)
AUTH_JWT_SECRET=use-a-robust-secret
# JWT lifetime (zeit/ms format, e.g. `7d`, `1h`)
AUTH_JWT_EXPIRES_IN=7d
# Web URL the user is redirected to after Pro Connect login when their account does not yet exist (onboarding flow)
AUTH_CREATE_USER_ACCOUNT_URL=http://localhost:3000/premiers-pas/identite
# API URL the Pro Connect provider redirects to at the end of the logout flow (`post_logout_redirect_uri`)
AUTH_LOGOUT_CALLBACK_URL=http://localhost:4000/api/auth/logout-callback
# Lifetime of email magic-link tokens (in minutes), shown to the user in the email body
AUTH_LINK_TOKEN_EXPIRATION_MINUTES=15

# DB
# PostgreSQL port (used by Knex to connect)
DATABASE_PORT=5432
# PostgreSQL username
DATABASE_USER=postgres
# PostgreSQL password (sensitive)
DATABASE_PASSWORD=use-a-robust-password
# PostgreSQL database name
DATABASE_DB_NAME=benefriches_db

# Pro Connect
# Pro Connect OIDC provider hostname — `fca.integ01.dev-agentconnect.fr` for integration, prod hostname differs
PRO_CONNECT_PROVIDER_DOMAIN=fca.integ01.dev-agentconnect.fr
# Pro Connect OAuth client ID issued by the provider
PRO_CONNECT_CLIENT_ID=use-your-client-id
# Pro Connect OAuth client secret (sensitive)
PRO_CONNECT_CLIENT_SECRET=use-your-client-secret
# API URL Pro Connect redirects to after successful authentication (`redirect_uri`)
PRO_CONNECT_LOGIN_CALLBACK_URL=http://localhost:4000/api/auth/login-callback/pro-connect

# Mailer
# Mailcatcher web UI port (dev-only, browse to view emails the API sent via SMTP); consumed by docker-compose.db.yml, not by the API
MAILCATCHER_HTTP_PORT=1080
# SMTP server hostname used to send auth/magic-link emails (Mailcatcher in dev, real SMTP in prod)
SMTP_HOST=127.0.0.1
# SMTP server port (1025 = Mailcatcher default)
SMTP_PORT=1025
# SMTP username for authentication
SMTP_USER=benefriches-test
# SMTP password for authentication (sensitive)
SMTP_PASSWORD=secret-for-tests
# `From:` address used on outgoing emails (must be allowed by the SMTP relay in prod)
SMTP_FROM_ADDRESS=dev@benefriches.com

# Connect CRM
# ADEME Connect CRM base URL
CONNECT_CRM_HOST=https://connectcrm.com
# Connect CRM OAuth client ID for newsletter sync
CONNECT_CRM_CLIENT_ID=use-your-client-id
# Connect CRM OAuth client secret for newsletter sync (sensitive)
CONNECT_CRM_CLIENT_SECRET=use-your-client-secret

# Mutafriches
# Mutafriches API base URL — used server-side to fetch reconversion compatibility evaluations by id
MUTAFRICHES_API_URL=https://mutafriches.incubateur.ademe.dev/
