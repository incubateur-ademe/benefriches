{
  "name": "web",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "setup-env-vars": "export $(cat .env | grep 'WEBAPP_' | xargs) && chmod +x scripts/generateEnvVarsJsFile.sh && bash scripts/generateEnvVarsJsFile.sh public/js/env-vars.js",
    "dev": "vite",
    "build": "tsc && vite build",
    "format": "prettier --write --cache \"./**/*.{js,jsx,ts,tsx,css,md,json}\" src/",
    "format:check": "prettier --check --cache  \"./**/*.{js,jsx,ts,tsx,css,md,json}\" src/",
    "lint": "oxlint --type-aware",
    "test:unit": "vitest --globals=true",
    "test": "pnpm test:unit",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "preinstall": "npx only-allow pnpm",
    "## needed by @codegouvfr/react-dsfr": "//",
    "postinstall": "copy-dsfr-to-public",
    "predev": "react-dsfr update-icons",
    "prebuild": "react-dsfr update-icons"
  },
  "dependencies": {
    "@codegouvfr/react-dsfr": "~1.32.4",
    "@headlessui/react": "^2.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@reduxjs/toolkit": "~2.12.0",
    "clsx": "~2.1.1",
    "crisp-sdk-web": "1.1.2",
    "date-fns": "~4.4.0",
    "highcharts": "12.6.0",
    "highcharts-react-official": "3.2.3",
    "leaflet": "~1.9.4",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "react-hook-form": "~7.79.0",
    "react-leaflet": "~5.0.0",
    "react-pdf-tailwind": "^3.0.0",
    "react-redux": "~9.3.0",
    "reduce-reducers": "~1.0.4",
    "shared": "workspace:*",
    "type-route": "~1.1.0",
    "uuid": "~14.0.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "~6.0.2",
    "@types/geojson": "~7946.0.16",
    "@types/leaflet": "~1.9.21",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.2",
    "globals": "~17.6.0",
    "jsdom": "~29.1.1",
    "tailwindcss": "~4.3.1",
    "vite": "~8.0.16",
    "vite-plugin-node-polyfills": "~0.28.0"
  }
}
