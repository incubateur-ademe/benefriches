# API base URL — used by Vite dev server to proxy `/api/*` to the backend (see vite.config.ts)
API_HOST=http://localhost:4000
# Matomo tracker URL (analytics); leave empty to disable Matomo tracking
WEBAPP_MATOMO_URL=
# Matomo site id (analytics); presence of this value enables tracking
WEBAPP_MATOMO_SITE_ID=
# Mutafriches iframe `src` URL embedded on the reconversion-compatibility page; also used as `event.origin` allowlist for postMessage
WEBAPP_MUTAFRICHES_FRAME_SRC=https://mutafriches.incubateur.ademe.dev/
# Integrator id passed to Mutafriches as a query param to identify the embedding host
WEBAPP_MUTAFRICHES_INTEGRATOR=demo
# Crisp chat website id (support widget); leave empty to disable Crisp
WEBAPP_CRISP_WEBSITE_ID=

# Feature flags (WEBAPP_FF_ prefix)
# Comma-separated list of project categories selectable by users when creating a reconversion project
WEBAPP_FF_ALLOWED_DEVELOPMENT_PLAN_CATEGORIES=RENEWABLE_ENERGY,URBAN_PROJECT
# Enables the "urban zone" site nature option in the site creation flow (`1`/`true` to enable)
WEBAPP_FF_SITE_URBAN_ZONE_ENABLED=
# Enables the buildings reuse chapter in the urban project creation/update wizard (`1`/`true` to enable)
WEBAPP_FF_URBAN_PROJECT_BUILDINGS_REUSE_CHAPTER_ENABLED=
